APP_ENV=development
APP_ADDR=:8080
APP_KEY=replace-with-local-admin-appkey
ASSETS_DIR=assets
CONFIG_ENCRYPTION_KEY=replace-with-32-byte-local-secret

# MySQL 8.0 is required before first startup. Create the database first:
# CREATE DATABASE supervisor_game CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#
# Example for docker-compose MySQL:
# user: password=supervisor, database=supervisor_game, host=127.0.0.1:3306
DB_DSN=supervisor:supervisor@tcp(127.0.0.1:3306)/supervisor_game?charset=utf8mb4&parseTime=True&loc=Local
#
# Example for a remote MySQL server. Do not commit real passwords:
# DB_DSN=root:your-password@tcp(8.148.146.195:3336)/supervisor_game?charset=utf8mb4&parseTime=True&loc=Local
